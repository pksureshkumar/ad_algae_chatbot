# Azure OpenAI credentials (required)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Deployment names — these must match the names you gave each deployment
# in Azure AI Studio (not the underlying model names).
AZURE_OPENAI_DEPLOYMENT_LLM=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_VISION=gpt-4o
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large
